{
  "expo": {
    "name": "CatApp",
    "slug": "catapp-waracle",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f93b02"
    },
    "scheme": "catapp",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.waracle.catapp",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow CatApp to access your photos so you can upload cat images.",
        "NSPhotoLibraryAddUsageDescription": "Allow CatApp to save photos to your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#f93b02"
      },
      "package": "com.waracle.catapp",
      "permissions": ["READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow CatApp to access your photos so you can upload cat images."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
