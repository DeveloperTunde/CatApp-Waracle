{
  "name": "catapp-waracle",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --watchAll=false",
    "test:coverage": "jest --coverage --watchAll=false",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@shopify/flash-list": "^2.0.2",
    "@tanstack/react-query": "^5.100.9",
    "axios": "^1.16.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "expo": "~55.0.23",
    "expo-constants": "~55.0.16",
    "expo-image-picker": "~55.0.20",
    "expo-linking": "^55.0.15",
    "expo-router": "~55.0.14",
    "expo-status-bar": "~55.0.6",
    "immer": "^11.1.6",
    "react": "^19.2.0",
    "react-native": "^0.83.6",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "^4.2.1",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.23.0",
    "react-native-worklets": "^0.8.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.14",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "ajv": "^8.20.0",
    "babel-jest": "^30.3.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.17",
    "react-test-renderer": "19.2.5",
    "typescript": "^5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!(jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@shopify/flash-list|zustand|immer)"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/android/",
      "/ios/"
    ],
    "collectCoverageFrom": [
      "services/**/*.ts",
      "stores/**/*.ts",
      "hooks/**/*.ts",
      "components/**/*.tsx",
      "!**/*.d.ts"
    ]
  },
  "private": true
}
